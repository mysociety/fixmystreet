say 'Creating 20 synthetic Tyseley reports';

for my $report (@reports) {
    my $reported_at = DateTime->now(time_zone => 'Europe/London')
        ->subtract(days => $report->{days_ago}, hours => 9)
        ->set_hour(8)
        ->set_minute(0)
        ->set_second(0);

    my $problem = FixMyStreet::DB::Factory::Problem->create_problem({
        body => $body,
        areas => ",$area_id,",
        user => $users{$report->{reporter}},
        postcode => $report->{postcode},
        latitude => $report->{latitude},
        longitude => $report->{longitude},
        cobrand => 'birmingham',
        title => $report->{title},
        detail => $report->{detail},
        category => $report->{category},
        confirmed => $reported_at,
        whensent => $reported_at,
        lastupdate => $reported_at,
    });

    my $last_update = $reported_at->clone;
    for my $comment (@{ $report->{comments} }) {
        my $comment_time = $reported_at->clone->add(days => $comment->{days_after}, hours => 2);
        FixMyStreet::DB::Factory::Comment->create({
            problem => $problem,
            user => $users{$comment->{by}},
            text => $comment->{text},
            problem_state => $comment->{state},
            confirmed => DateTime::Format::Pg->format_datetime($comment_time),
        });
        $last_update = $comment_time;
        if ($comment->{state}) {
            $problem->state($comment->{state});
        }
    }

    $problem->lastupdate(DateTime::Format::Pg->format_datetime($last_update));
    $problem->update;
}

