#!/usr/bin/env perl
use strict;
use warnings;

use FixMyStreet::Cobrand::Bexley;

use Text::CSV;
use Data::Dumper;

# Export a CSV from Postgres using this SQL:
#
# select p.id, p.name, replace(detail, E'Garden Subscription\n\n', '') as address, p.created, uprn, p.extra->>'direct_debit_customer_id' as dd_customer_id
# from problem p join users u on p.user_id = u.id
# where uprn in (
#   select uprn from problem
#   where bodies_str='2494' and category='Cancel Garden Subscription' and external_id is null and state='confirmed' and user_id=557571 and extra->>'direct_debit_contract_id' is not null order by id
# )
# and category like '%Garden Subscription' and p.extra->>'direct_debit_customer_id' is not null order by created;

my ($input_path) = @ARGV;

die "Usage: $0 <bexley-export-from-postgres.csv>\n" unless $input_path;

my $csv = Text::CSV->new({ binary => 1, auto_diag => 1 });

open my $in, '<:encoding(utf8)', $input_path or die "Can't open $input_path: $!";

my $out = \*STDOUT;
binmode $out, ':encoding(utf8)';

my $headers = $csv->getline($in);
$csv->column_names($headers);

$csv->eol("\n");
$csv->print($out, [qw(wasteworks_url name address created uprn agile_status agile_end_date dd_status)]);

my $b = FixMyStreet::Cobrand::Bexley->new;
my $agile = $b->agile;
my $ap = $b->get_dd_integration;

my %uprn_to_data;
my @uprn_order;

while (my $row = $csv->getline_hr($in)) {
    my $uprn = $row->{uprn};
    push @uprn_order, $uprn unless exists $uprn_to_data{$uprn};
    $uprn_to_data{$uprn} //= { rows => [], customer_ids => [] };
    push @{ $uprn_to_data{$uprn}{rows} }, $row;
    if ($row->{dd_customer_id}) {
        push @{ $uprn_to_data{$uprn}{customer_ids} }, $row->{dd_customer_id};
    }
}

close $in;

for my $uprn (@uprn_order) {
    my $data = $uprn_to_data{$uprn};
    my $customer_ids = $data->{customer_ids};
    next unless @$customer_ids;

    my $res = $agile->CustomerSearch($uprn);
    die "Agile API error for UPRN $uprn\n" . Dumper($res) if $res->{error};

    my $agile_status = 'NOACTIVE';
    my $agile_end_date = '';
    OUTER: for my $customer (@{ $res->{Customers} || [] }) {
        for my $contract (@{ $customer->{ServiceContracts} || [] }) {
            next unless $contract->{UPRN} == $uprn;
            next if $contract->{ServiceContractStatus} eq 'NOACTIVE';
            $agile_status = $contract->{ServiceContractStatus};
            $agile_end_date = $contract->{EndDate} // '';
            last OUTER;
        }
    }

    my $latest_contract;
    my $latest_customer_id;
    for my $customer_id (@$customer_ids) {
        my $contracts = $ap->get_contracts($customer_id);
        for my $contract (@$contracts) {
            die "Contract missing Start:\n" . Dumper($contract) unless $contract->{Start};
            if (!$latest_contract || $contract->{Start} gt $latest_contract->{Start}) {
                $latest_contract = $contract;
                $latest_customer_id = $customer_id;
            }
        }
    }
    my $has_active_dd = $latest_contract && $latest_contract->{Status} eq 'Active';
    my $dd_status = $latest_contract ? "$latest_contract->{Id}=$latest_contract->{Status}" : '';
    my $agile_is_active = $agile_status ne 'NOACTIVE';
    my $flagged = ($agile_is_active && !$has_active_dd)
        || (!$agile_is_active && $has_active_dd);
    next unless $flagged;

    my @matching_rows = $latest_customer_id
        ? grep { ($_->{dd_customer_id} // '') eq $latest_customer_id } @{ $data->{rows} }
        : @{ $data->{rows} };

    for my $row (@matching_rows) {
        $csv->print($out, [
            "https://fix.bexley.gov.uk/admin/report_edit/$row->{id}",
            $row->{name},
            $row->{address},
            substr($row->{created}, 0, 10),
            $uprn,
            $agile_status,
            $agile_end_date,
            $dd_status,
        ]);
    }
}
