#!/usr/bin/env perl
#
# Close reports in 'Parking enforcement' (display name 'Parking illegally') category older than a number of days

use strict;
use warnings;

BEGIN {
    use File::Basename qw(dirname);
    use File::Spec;
    my $d = dirname(File::Spec->rel2abs($0));
    require "$d/../../setenv.pl";
}

use CronFns;
use Getopt::Long::Descriptive;
use FixMyStreet::Script::UK::AutoClose;

my $site = CronFns::site(FixMyStreet->config('BASE_URL'));
CronFns::language($site);

my $default_text = 'Thank you for this report. It has been sent to our team of enforcement officers who will have reviewed the case and taken action where they were able to do so. This report has now been closed automatically.';

my ($opts, $usage) = describe_options(
    '%c %o',
    ['commit!', "actually close reports and send emails. Omitting this flag will do a dry-run"],
    ['closure_text=s', "text of the message to add to reports", { default => $default_text } ],
    ['days:i', "Number of days before autoclosing", { default => 5, callbacks => { positive => sub { shift() > 0 } } } ],
    ['help|h', "print usage message and exit" ],
    { show_defaults => 1 }
);
print($usage->text), exit if $opts->help;

warn "DRY RUN: use --commit to close reports\n" unless $opts->commit;

FixMyStreet::Script::UK::AutoClose->new(
    commit => $opts->commit,
    retain_alerts => 1,
    body_name => 'Surrey County Council',
    category => 'Parking enforcement',
    to => $opts->days,
    closure_text => $opts->closure_text,
)->close;
